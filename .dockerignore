local_chdb_data/
chdb_data/
# Host-baked store. The normal Dockerfile bakes data IN-CONTAINER into
# local_chdb_data, then runs `COPY . .` — without this ignore the ~940MB host
# bake would be copied in on top of the in-container bake, ~doubling the image
# and busting the 2048MB AgentCore Runtime cap. NOTE: the FALLBACK build
# (Dockerfile.prebaked) needs this dir IN the context — comment this line out
# before building with Dockerfile.prebaked.
full_chdb_data/
