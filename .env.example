# AWS Credentials (for local development)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Bedrock Model
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0

# chDB
CHDB_DATA_PATH=/app/local_chdb_data

# Weather
WEATHER_MOUNT_PATH=/mnt/noaa-gsod

# ClickHouse Cloud — federation "Historical Lake" leg (optional).
# Powers the 2023 slice of analyze_fleet_across_clouds via chDB remoteSecure().
# The federation tool derives the native-secure host (port 9440) from this URL;
# leg is silently skipped when CLICKHOUSE_PASSWORD is unset. Store the real
# secret in .env.local (gitignored) or SSM — never commit it.
CLICKHOUSE_URL=https://<your-service>.<region>.aws.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# PostgreSQL — federation zone-lookup leg (the paper's postgresql() leg).
# Defaults match the compose.yml `postgres` service; for local-dev (uvicorn on
# host) the published port is 55432. Powers analyze_zone_tipping.
POSTGRES_HOST=localhost
POSTGRES_PORT=55432
POSTGRES_DB=nyctaxi
POSTGRES_USER=taxi
POSTGRES_PASSWORD=taxi

# AgentCore Memory (optional — agent works without it)
AGENTCORE_MEMORY_ID=

# Langfuse OTEL Tracing (optional — agent works without it)
# Generate these from your Langfuse Cloud project settings
OTEL_EXPORTER_OTLP_ENDPOINT=https://us.cloud.langfuse.com/api/public/otel
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64(pk:sk)>,x-langfuse-ingestion-version=4
LANGFUSE_TRACING_ENVIRONMENT=DEV
DISABLE_ADOT_OBSERVABILITY=true

# Runtime
IS_PROD=false
